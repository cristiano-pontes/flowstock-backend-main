@page
@model FlowStock_Backend.Pages.Products.CreateModel

<h2>Create Product</h2>

<form method="post">
    <div>
        <label>Name</label>
        <input asp-for="Product.Name" />
    </div>

    <div>
        <label>Barcode</label>
        <input asp-for="Product.Barcode" />
    </div>

    <div>
        <label>Description</label>
        <input asp-for="Product.Description" />
    </div>

    <div>
        <label>Price</label>
        <input asp-for="Product.Price" />
    </div>

    <div>
        <label>Quantity</label>
        <input asp-for="Product.Quantity" />
    </div>

    <div>
        <label>Minimum Stock</label>
        <input asp-for="Product.MinimumStock" />
    </div>

    <div>
        <label>Supplier</label>
        <select asp-for="Product.SupplierId">
            <option value="">Select</option>
            @foreach (var supplier in Model.Suppliers)
            {
                <option value="@supplier.Id">@supplier.Name</option>
            }
        </select>
    </div>

    <button type="submit">Save</button>
</form>